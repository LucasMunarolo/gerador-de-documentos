# ============================================
# Banco de Dados PostgreSQL
# Usado tanto no docker-compose.dev.yml quanto no docker-compose.yml
# ============================================
POSTGRES_DB=geradordocumentos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================
# Conexão do backend com o banco (docker-compose.yml / produção)
# Em desenvolvimento local (mvn spring-boot:run), use:
#   jdbc:postgresql://localhost:5432/geradordocumentos
# Dentro do docker-compose.yml, o backend acessa pelo nome do serviço:
#   jdbc:postgresql://postgres:5432/geradordocumentos
# ============================================
DB_URL=jdbc:postgresql://postgres:5432/geradordocumentos
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ============================================
# Cloudinary (upload de imagens)
# ============================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# Spring profile ativo (usado pelo docker-compose.yml)
# ============================================
SPRING_PROFILES_ACTIVE=docker

# ============================================
# Frontend - URL do backend (build-time, docker-compose.yml)
# ============================================
FRONTEND_API_URL=http://localhost:8080